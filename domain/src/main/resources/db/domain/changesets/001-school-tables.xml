<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">

    <changeSet id="school-001-teachers" author="school">
        <createTable tableName="teachers">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="public_id" type="VARCHAR(36)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="employee_code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="join_date" type="DATE"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP"/>
            <column name="deleted_by" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_teachers_tenant_id"
                baseTableName="teachers" baseColumnNames="tenant_id"
                referencedTableName="tenants" referencedColumnNames="id"/>

        <createIndex indexName="idx_teachers_tenant_id" tableName="teachers">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_teachers_deleted" tableName="teachers">
            <column name="deleted"/>
        </createIndex>
        <createIndex indexName="uq_teachers_employee_code_tenant" tableName="teachers" unique="true">
            <column name="employee_code"/>
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="school-002-classrooms" author="school">
        <createTable tableName="classrooms">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="public_id" type="VARCHAR(36)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="class_code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="grade" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="section" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="academic_year" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="class_teacher_id" type="BIGINT"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP"/>
            <column name="deleted_by" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_classrooms_tenant_id"
                baseTableName="classrooms" baseColumnNames="tenant_id"
                referencedTableName="tenants" referencedColumnNames="id"/>
        <addForeignKeyConstraint
                constraintName="fk_classrooms_class_teacher_id"
                baseTableName="classrooms" baseColumnNames="class_teacher_id"
                referencedTableName="teachers" referencedColumnNames="id"/>

        <createIndex indexName="idx_classrooms_tenant_id" tableName="classrooms">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_classrooms_deleted" tableName="classrooms">
            <column name="deleted"/>
        </createIndex>
        <createIndex indexName="uq_classrooms_code_tenant" tableName="classrooms" unique="true">
            <column name="class_code"/>
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="school-003-students" author="school">
        <createTable tableName="students">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="public_id" type="VARCHAR(36)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="student_code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)"/>
            <column name="date_of_birth" type="DATE"/>
            <column name="enrollment_status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP"/>
            <column name="deleted_by" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_students_tenant_id"
                baseTableName="students" baseColumnNames="tenant_id"
                referencedTableName="tenants" referencedColumnNames="id"/>

        <createIndex indexName="idx_students_tenant_id" tableName="students">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_students_deleted" tableName="students">
            <column name="deleted"/>
        </createIndex>
        <createIndex indexName="uq_students_code_tenant" tableName="students" unique="true">
            <column name="student_code"/>
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
