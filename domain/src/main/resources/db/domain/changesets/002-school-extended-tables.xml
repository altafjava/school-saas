            <column name="public_id" type="VARCHAR(36)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="subject" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="classroom_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="scheduled_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="max_marks" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP"/>
            <column name="deleted_by" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_exams_tenant_id"
                baseTableName="exams" baseColumnNames="tenant_id"
                referencedTableName="tenants" referencedColumnNames="id"/>
        <addForeignKeyConstraint
                constraintName="fk_exams_classroom_id"
                baseTableName="exams" baseColumnNames="classroom_id"
                referencedTableName="classrooms" referencedColumnNames="id"/>

        <createIndex indexName="idx_exams_tenant_id" tableName="exams">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_exams_deleted" tableName="exams">
            <column name="deleted"/>
        </createIndex>
        <createIndex indexName="idx_exams_scheduled_at" tableName="exams">
            <column name="scheduled_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="school-006-attendance" author="school">
        <createTable tableName="attendance">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="public_id" type="VARCHAR(36)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="student_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="classroom_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="attendance_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="marked_by" type="VARCHAR(100)"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP"/>
            <column name="deleted_by" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_attendance_tenant_id"
                baseTableName="attendance" baseColumnNames="tenant_id"
                referencedTableName="tenants" referencedColumnNames="id"/>
        <addForeignKeyConstraint
                constraintName="fk_attendance_student_id"
                baseTableName="attendance" baseColumnNames="student_id"
                referencedTableName="students" referencedColumnNames="id"/>
        <addForeignKeyConstraint
                constraintName="fk_attendance_classroom_id"
                baseTableName="attendance" baseColumnNames="classroom_id"
                referencedTableName="classrooms" referencedColumnNames="id"/>

        <createIndex indexName="idx_attendance_tenant_id" tableName="attendance">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_attendance_deleted" tableName="attendance">
            <column name="deleted"/>
        </createIndex>
        <createIndex indexName="idx_attendance_student_date" tableName="attendance">
            <column name="student_id"/>
            <column name="attendance_date"/>
        </createIndex>
        <createIndex indexName="idx_attendance_classroom_date" tableName="attendance">
            <column name="classroom_id"/>
            <column name="attendance_date"/>
        </createIndex>
        <!-- Prevent duplicate attendance records for a student in a classroom on the same day -->
        <createIndex indexName="uq_attendance_student_classroom_date_tenant" tableName="attendance" unique="true">
            <column name="student_id"/>
            <column name="classroom_id"/>
            <column name="attendance_date"/>
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="school-007-grades" author="school">
        <createTable tableName="grades">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="public_id" type="VARCHAR(36)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="student_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="subject" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="exam_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="marks" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="grade_letter" type="VARCHAR(5)">
                <constraints nullable="false"/>
            </column>
            <column name="graded_by" type="VARCHAR(100)"/>
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP"/>
            <column name="deleted_by" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(100)"/>
            <column name="updated_by" type="VARCHAR(100)"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_grades_tenant_id"
                baseTableName="grades" baseColumnNames="tenant_id"
                referencedTableName="tenants" referencedColumnNames="id"/>
        <addForeignKeyConstraint
                constraintName="fk_grades_student_id"
                baseTableName="grades" baseColumnNames="student_id"
                referencedTableName="students" referencedColumnNames="id"/>
        <addForeignKeyConstraint
                constraintName="fk_grades_exam_id"
                baseTableName="grades" baseColumnNames="exam_id"
                referencedTableName="exams" referencedColumnNames="id"/>

        <createIndex indexName="idx_grades_tenant_id" tableName="grades">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_grades_deleted" tableName="grades">
            <column name="deleted"/>
        </createIndex>
        <createIndex indexName="idx_grades_student_id" tableName="grades">
            <column name="student_id"/>
        </createIndex>
        <!-- One grade record per student per exam -->
        <createIndex indexName="uq_grades_student_exam_tenant" tableName="grades" unique="true">
            <column name="student_id"/>
            <column name="exam_id"/>
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

